# NATS Dashboard - Environment Variables
# Copy to .env and customize for your deployment.

# Optional: Docker image tag (default: 0.0.1). Bump when deploying new versions.
# DASHBOARD_VERSION=0.0.1

# Required: NATS server URL (e.g. nats://host:4222)
NATS_URL=nats://localhost:4222

# Optional: HTTP monitoring URL (e.g. http://host:8222). Auto-derived from NATS_URL if unset.
# Set when NATS host differs from dashboard (e.g. Docker: http://nats:8222)
# NATS_MONITORING_URL=http://localhost:8222

# Required if NATS server uses token auth
NATS_TOKEN=

# Optional: Context name shown in UI (default: docker)
NATS_NAME=docker

# Optional: Human label in context switcher (default: Docker NATS Server)
NATS_DESCRIPTION=Docker NATS Server

# Optional: HTTP port the dashboard listens on (default: 3000)
PORT=3000

# Login protection: when both are set, users must sign in to access the dashboard.
# Credentials are validated server-side only — never exposed to the browser.
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=your-secure-password
