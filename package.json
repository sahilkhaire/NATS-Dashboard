{
  "name": "nats-dashboard",
  "private": true,
  "version": "0.0.7",
  "type": "module",
  "scripts": {
    "sync-context": "node scripts/sync-nats-context.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "docker:build": "docker build -t sahilkhaire/nats-dashboard:$(node -p \"require('./package.json').version\") -t sahilkhaire/nats-dashboard:latest .",
    "docker:push": "npm run docker:build && docker push sahilkhaire/nats-dashboard:$(node -p \"require('./package.json').version\") && docker push sahilkhaire/nats-dashboard:latest"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "nats": "^2.29.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11"
  }
}
